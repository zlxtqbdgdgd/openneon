# feat-039 · 冷启 warming_up 状态机 policy.yaml 示例
# 详设: features/feat-039-L3-neon-baseline-state-warming-up.html §3.4
# ADR:  docs/adr/0013-warming-up-state-machine-exit-conditions.md
#
# 用途: operator 可按 workload 自定义冷启状态机退出条件。本文件不是 compute_ctl 直接
# 读取的输入,而是 mcp / control-plane 把同名 GUC 注入 ComputeSpec.cluster.settings
# 后,compute_tools::config::write_postgres_conf() 把它们写到 postgresql.conf。
#
# 三 GUC (compute_tools 默认在 src/warming_up.rs::defaults 模块):
#   - neon.warming_up_min_seconds   : 最小热身时间(秒) [默认 30]
#   - neon.warming_up_lfc_target    : LFC 命中率目标 [0.0, 1.0] [默认 0.8]
#   - neon.warming_up_max_seconds   : 兜底最大热身时间(秒) [默认 300]
#
# 退出条件: (elapsed >= min) AND (lfc_ratio >= target),否则 max 强制兜底 + warn。

# 默认 profile (适合标准 OLTP)。
default:
  neon.warming_up_min_seconds: 30
  neon.warming_up_lfc_target: 0.8
  neon.warming_up_max_seconds: 300

# 高负载 / 大 LFC profile: 允许较长热身,LFC ratio 目标提高,降低误报。
high_load:
  neon.warming_up_min_seconds: 60
  neon.warming_up_lfc_target: 0.9
  neon.warming_up_max_seconds: 600

# 低延迟敏感 / 小 LFC profile: 短热身,LFC ratio 目标降低,牺牲精度换 wake 快速 ready。
low_latency:
  neon.warming_up_min_seconds: 10
  neon.warming_up_lfc_target: 0.6
  neon.warming_up_max_seconds: 120

# 关闭 warming_up (合规/排障场景 — 强制状态机立即退出 + 不贴 label,等价于 disabled)。
# 不建议生产使用,会导致 baseline 算法被冷启段污染。
disabled:
  neon.warming_up_min_seconds: 0
  neon.warming_up_lfc_target: 0.01
  neon.warming_up_max_seconds: 1
